# ============================================================
# Trans/Act Journal Platform — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# Django core
SECRET_KEY=change-me-generate-with-python-secrets-token-hex-50
DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.development
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DB_NAME=transact_journal
DB_USER=transact
DB_PASSWORD=devpassword
DB_HOST=localhost
DB_PORT=5432

# Superuser (created by setup script)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=change-me-strong-password
DJANGO_SUPERUSER_EMAIL=admin@trans-act-journal.org

# Redis / Celery
CELERY_BROKER_URL=redis://localhost:6379/0

# ─── Email ───────────────────────────────────────────────────
# Backend: 'mailersend' | 'sendgrid' | 'mailgun' | 'console' (dev default)
ANYMAIL_BACKEND=mailersend
MAILERSEND_API_TOKEN=
DEFAULT_FROM_EMAIL=noreply@trans-act-journal.org
DEFAULT_FROM_NAME=Trans/Act Journal
SERVER_EMAIL=admin@trans-act-journal.org

# ─── ORCID OAuth ─────────────────────────────────────────────
# Register at https://orcid.org/developer-tools
ORCID_OAUTH_ENABLED=False
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=

# ─── DOI / Crossref ──────────────────────────────────────────
# Requires Crossref membership — https://www.crossref.org
DOI_ENABLED=False
CROSSREF_LOGIN=
CROSSREF_PASSWORD=
CROSSREF_DEPOSITOR_NAME=Trans/Act Journal
CROSSREF_DEPOSITOR_EMAIL=

# ─── Turnitin ────────────────────────────────────────────────
# Requires institutional TCA API access
TURNITIN_ENABLED=False
TURNITIN_API_KEY=
TURNITIN_BASE_URL=https://api.turnitin.com

# ─── AI Features (reviewer semantic matching) ────────────────
# Scaffolded. Enable only when API key is available.
AI_FEATURES_ENABLED=False
OPENAI_API_KEY=

# ─── Storage ─────────────────────────────────────────────────
# Local filesystem (default for dev and initial production)
MEDIA_ROOT=./media
USE_S3=False
# S3-compatible storage (Phase 2 upgrade — see README)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=

# ─── Production only ─────────────────────────────────────────
# CORS_ALLOWED_ORIGINS=https://trans-act-journal.org
# SENTRY_DSN=
